# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# OPENAI_API_KEY: Required for OpenAI voice interaction.
# Users configure this via the Secrets panel in the AI Studio UI.
OPENAI_API_KEY="MY_OPENAI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# ELEVENLABS_API_KEY: Required for ElevenLabs Conversational AI.
# Create an API key at https://elevenlabs.io/app/settings/api-keys.
# Required for the server-side signed URL flow and for creating the default in-code agent.
ELEVENLABS_API_KEY="MY_ELEVENLABS_API_KEY"

# ELEVENLABS_AGENT_ID: The agent ID from the ElevenLabs UI.
# Optional override. If omitted, the app creates and reuses the default Picnic agent defined in code.
ELEVENLABS_AGENT_ID="MY_ELEVENLABS_AGENT_ID"

# NEXT_PUBLIC_ELEVENLABS_AGENT_ID: Optional public agent ID.
# If set, the client uses the documented public-agent WebSocket flow directly with agentId.
NEXT_PUBLIC_ELEVENLABS_AGENT_ID=""
